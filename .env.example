# Server — copy to .env and fill in real values

# App
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# Database
MONGODB_URI=mongodb://127.0.0.1:27017/webinar-page

# Clerk (must match client VITE_CLERK_PUBLISHABLE_KEY app)
CLERK_SECRET_KEY=sk_test_your_secret_key
CLERK_PUBLISHABLE_KEY=pk_test_your_publishable_key

# Razorpay (use test keys in development)
RAZORPAY_KEY_ID=rzp_test_your_key_id
RAZORPAY_KEY_SECRET=your_razorpay_secret

# Resend
RESEND_API_KEY=re_your_resend_api_key
RESEND_FROM_EMAIL=Webinar <onboarding@resend.dev>

# Webinar details for reminder emails (optional — defaults in src/config/webinar.js)
# WEBINAR_DATE=2026-06-20T00:00:00.000Z
# WEBINAR_TIME=11:30 AM
# WEBINAR_PRICE=499
# WEBINAR_VENUE=Live Online Webinar
# WEBINAR_MEETING_LINK=
